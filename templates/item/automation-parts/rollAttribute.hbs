<div>
  <div class="form-group cgd-custom">
    <label for="system.automations.{{key}}.attribute">{{localize
      "CORIOLIS_TGD.Automation.FIELDS.attribute.label"}}</label>
    <select name="system.automations.{{key}}.attribute">
      {{selectOptions @root.config.Attributes.choices selected=automation.attribute
      blank="CORIOLIS_TGD.Actor.base.FIELDS.attributes.selectWhenRolling.label" localize=true}}
    </select>
  </div>
  <div class="form-group cgd-custom">
    <label for="system.automations.{{@key}}.requireAttribute">{{localize
      "CORIOLIS_TGD.Automation.FIELDS.rollAttribute.requireAttribute.label"}}</label>
    <input type="checkbox" name="system.automations.{{@key}}.requireAttribute" {{checked
      automation.requireAttribute}} />
  </div>
  <div class="form-group cgd-custom">
    <label for="system.automations.{{@key}}.canChangeAttribute">{{localize
      "CORIOLIS_TGD.Automation.FIELDS.rollAttribute.canChangeAttribute.label"}}</label>
    <input type="checkbox" name="system.automations.{{@key}}.canChangeAttribute" {{checked
      automation.canChangeAttribute}} />
  </div>
  {{#if @root.showDefaultTalent}}
  {{#if @root.talentChoices}}
  <div class="form-group cgd-custom">
    <label for="system.automations.{{key}}.defaultTalent">{{localize
      "CORIOLIS_TGD.Automation.FIELDS.defaultTalent.label"}}</label>
    <select name="system.automations.{{key}}.defaultTalent">
      {{selectOptions @root.talentChoices selected=automation.defaultTalent
      blank=(localize "CORIOLIS_TGD.Automation.FIELDS.defaultTalent.blank")}}
    </select>
  </div>
  {{/if}}
  {{/if}}
  {{#if @root.showDefaultGear}}
  {{#if @root.gearChoices}}
  <div class="form-group cgd-custom">
    <label for="system.automations.{{key}}.defaultGear">{{localize
      "CORIOLIS_TGD.Automation.FIELDS.defaultGear.label"}}</label>
    <select name="system.automations.{{key}}.defaultGear">
      {{selectOptions @root.gearChoices selected=automation.defaultGear
      blank=(localize "CORIOLIS_TGD.Automation.FIELDS.defaultGear.blank")}}
    </select>
  </div>
  {{/if}}
  {{/if}}
</div>